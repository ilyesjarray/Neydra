{
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(self), geolocation=()" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/js/:path*",
      "has": [
        { "type": "header", "key": "Sec-Fetch-Dest", "value": "document" }
      ],
      "destination": "/welcome",
      "statusCode": 302
    },
    {
      "source": "/js/:path*",
      "missing": [
        { "type": "header", "key": "referer" }
      ],
      "destination": "/welcome",
      "statusCode": 302
    },
    {
      "source": "/js/:path*",
      "has": [
        {
          "type": "header",
          "key": "referer",
          "value": "^(?!https:\\/\\/(neydra\\.vercel\\.app|www\\.neydra\\.com|neydra\\.com|n-s-c\\.vercel\\.app)(?:\\/|:|$)).*$"
        }
      ],
      "destination": "/welcome",
      "statusCode": 302
    },
    {
      "source": "/assets/:path*",
      "has": [
        { "type": "header", "key": "Sec-Fetch-Dest", "value": "document" }
      ],
      "destination": "/welcome",
      "statusCode": 302
    },
